# Same-origin base path for the API. Requests to /api are proxied to the backend
# by next.config.ts, which keeps auth cookies first-party and avoids CORS.
NEXT_PUBLIC_API_URL=/api/v1

# Where the Next.js server proxies /api to. Server-only, not exposed to the browser.
BACKEND_INTERNAL_URL=http://localhost:5000

# Public name used across the UI.
NEXT_PUBLIC_APP_NAME=Recruitment Portal

# Optional request timeout in milliseconds for the Axios client.
NEXT_PUBLIC_API_TIMEOUT=15000
